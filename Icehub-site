<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>IceHub Script</title>

  <style>
    body {
      margin: 0;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: #0a0a0a;
      font-family: 'Courier New', monospace;
      color: #00bfff;
    }

    /* fundo animado azul */
    body::before {
      content: "";
      position: fixed;
      width: 100%;
      height: 100%;
      background: linear-gradient(120deg, #000, #001a33, #000);
      background-size: 300% 300%;
      animation: bg 6s infinite;
      z-index: -1;
    }

    @keyframes bg {
      0% {background-position: 0% 50%;}
      50% {background-position: 100% 50%;}
      100% {background-position: 0% 50%;}
    }

    .box {
      background: #111;
      padding: 40px;
      border-radius: 20px;
      width: 90%;
      max-width: 700px;
      text-align: center;
      box-shadow: 0 0 25px #00bfff;
    }

    h1 {
      margin-bottom: 20px;
      font-size: 34px;
      text-shadow: 0 0 10px #00bfff;
    }

    pre {
      background: #000;
      padding: 20px;
      border-radius: 12px;
      font-size: 16px;
      overflow-x: auto;
      user-select: none;
    }

    button {
      margin-top: 20px;
      padding: 15px 30px;
      font-size: 16px;
      border: none;
      border-radius: 10px;
      background: #00bfff;
      color: #000;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 0 12px #00bfff;
    }

    button:hover {
      transform: scale(1.08);
      background: #0099cc;
    }

    .status {
      margin-top: 15px;
      font-size: 14px;
      color: #aaa;
    }
  </style>
</head>
<body>

  <div class="box">
    <h1>⚡ IceHub Script ⚡</h1>

    <pre id="script">
loadstring(game:HttpGet("https://icehub.lol/raw/1912addd"))()
    </pre>

    <button onclick="copiar()">📋 Copiar Script</button>

    <div class="status" id="status">Pronto para copiar</div>
  </div>

  <script>
    function copiar() {
      const texto = `loadstring(game:HttpGet("https://icehub.lol/raw/1912addd"))()`;
      
      navigator.clipboard.writeText(texto);

      document.getElementById("status").innerText = "✅ Copiado com sucesso!";
    }
  </script>

</body>
</html>
